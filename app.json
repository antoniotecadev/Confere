{
  "expo": {
    "name": "Confere",
    "slug": "Confere",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "confere",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.antonioteca.Confere"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.antonioteca.Confere"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio",
      "expo-secure-store",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Allow Confere to access your camera to scan product information and take photos.",
          "enableCodeScanner": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://www.jitpack.io"
            ],
            "minSdkVersion": 24,
            "targetSdkVersion": 34,
            "kotlinVersion": "2.0.0",
            "proguardRules": "-keep class com.google.mlkit.** { *; }\n-keep class com.google.android.gms.tasks.** { *; }\n-keep class com.visioncameraocr.** { *; }\n-keep class com.mrousavy.camera.** { *; }\n-keep class com.swmansion.reanimated.** { *; }\n-keep class com.margelo.nitro.** { *; }",
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so",
                "**/libfbjni.so",
                "**/libhermes.so"
              ]
            }
          }
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "affbe6e4-fe21-440a-89bd-0dac3e1e0fb5"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/affbe6e4-fe21-440a-89bd-0dac3e1e0fb5"
    }
  }
}
